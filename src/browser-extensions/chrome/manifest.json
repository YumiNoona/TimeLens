{
  "manifest_version": 3,
  "name": "TimeLens Tracker",
  "version": "5.0.0",
  "description": "Sends browser activity to TimeLens",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://127.0.0.1:47821/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open TimeLens Dashboard"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
