{
  "manifest_version": 2,
  "name": "TimeLens Tracker",
  "version": "1.0",
  "description": "Sends browser activity to TimeLens",
  "permissions": ["tabs", "storage", "http://127.0.0.1:47821/*"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Open TimeLens Dashboard"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
