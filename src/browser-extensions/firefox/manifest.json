{
  "manifest_version": 2,
  "name": "TimeLens Tracker",
  "version": "6.0.0",
  "description": "Tracks and blocks distracting websites — part of the TimeLens activity tracker",
  "permissions": ["tabs", "storage", "webRequest", "webRequestBlocking", "<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "Open TimeLens Dashboard"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
